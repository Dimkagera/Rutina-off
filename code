import pandas as pd
import matplotlib.pyplot as plt
import asyncio
import os
import tempfile
from datetime import datetime
from io import BytesIO

from aiogram import Bot, Dispatcher, types, F
from aiogram.filters import Command
from aiogram.types import BufferedInputFile, FSInputFile

# ==================== НАСТРОЙКИ ====================
token = 'Your token'
bot = Bot(token=token)
dp = Dispatcher()

DATA_DIR = "user_expenses"
os.makedirs(DATA_DIR, exist_ok=True)

user_expected_file = {}
plan_mode_users = set()  # 🆕 Хранит ID пользователей, заполняющих план вручную

# ==================== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ====================
def get_user_file_path(user_id: int, prefix: str) -> str:
    return os.path.join(DATA_DIR, f"{prefix}_{user_id}.xlsx")

def load_or_create_df(path: str) -> pd.DataFrame:
    if os.path.exists(path):
        return pd.read_excel(path)
    return pd.DataFrame(columns=["Затраты", "Дата", "Деньги"])

# ==================== КОМАНДЫ ====================
