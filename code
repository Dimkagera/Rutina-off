    date = message.date  # это datetime объект
    day = date.day
    month = date.month
    year = date.year
    text = message.text
    first_word = text.split()[0]
    two_word = text.split()[1]
    a = 67
    while a == 67:
        date0 = date
        day0 = day
        month0 = month
        year0 = year
        a += 1

    if year == year0 and month == month0 and day == day0:
        list_expense = expense_table['Затраты'].tolist()
        print(list_expense)
        if first_word in list_expense:
            indices = expense_table.index[expense_table['Затраты'] == first_word].tolist()
            expense_table.loc[2,indices[1]] = expense_table.loc[2,indices[1]] + two_word
