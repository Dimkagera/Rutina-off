import pandas as pd
import matplotlib.pyplot as plt
import asyncio
import os
import tempfile
from datetime import datetime
from io import BytesIO

from aiogram import Bot, Dispatcher, types, F
from aiogram.filters import Command
from aiogram.types import BufferedInputFile, FSInputFile

# ==================== НАСТРОЙКИ ====================

token = 'Your_token'  # ВНИМАНИЕ: используйте переменные окружения в продакшене
bot = Bot(token=token)
dp = Dispatcher()

# Директория для хранения персональных файлов пользователей
DATA_DIR = "user_expenses"
os.makedirs(DATA_DIR, exist_ok=True)

# Словарь для отслеживания ожидаемого типа файла (чтобы избежать конфликта хендлеров)
user_expected_file = {}

# ==================== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ====================

def get_user_file_path(user_id: int, prefix: str) -> str:
    """Возвращает путь к персональному файлу пользователя"""
    return os.path.join(DATA_DIR, f"{prefix}_{user_id}.xlsx")

def load_or_create_df(path: str) -> pd.DataFrame:
    """Загружает DataFrame из Excel или создаёт пустой с нужными колонками"""
    if os.path.exists(path):
        return pd.read_excel(path)
    return pd.DataFrame(columns=["Затраты", "Дата", "Деньги"])

# ==================== ОБРАБОТЧИКИ КОМАНД ====================

