@dp.message(lambda msg: msg.text == "💰График расходов")
async def expenses_func(message: types.Message):
    global day0, day
    """
    Обработчик нажатия кнопки "💰График расходов"

    Строит линейный график расходов по категориям и дням недели.

    Args:
        message (types.Message): Объект сообщения от Telegram

    Global:
        expenses: DataFrame с данными о расходах

    Ожидаемая структура expenses:
        - Столбец 0: Названия категорий расходов
        - Столбцы 1-7: Расходы по дням недели

    Returns:
        Отправляет изображение графика пользователю или сообщение об ошибке
    """
    if expenses is None or expenses.empty:
        await message.answer("Нет данных для отображения")
        return
    else:
        await message.answer("График создается")

    # Создание графика
    plt.figure(figsize=(10, 6))
    x = day - day0

    # Построение линии для каждой категории расходов
    for i in range(len(expenses)):
        category = expenses.iloc[i, 0]  # Название категории
        y = expenses.iloc[i, 1:8].values  # Расходы по дням
        plt.plot(x, y, marker='o', linestyle='-', label=category)

    # Настройка внешнего вида графика
    plt.xlabel('Дни')
    plt.ylabel('Затраты')
    plt.title('График затрат по дням')
    plt.legend()
    plt.grid(True)
    plt.xticks(x)
    plt.tight_layout()

    # Сохранение графика в буфер
    buffer = BytesIO()
    plt.savefig(buffer, format='png', dpi=100, bbox_inches='tight')
    buffer.seek(0)
    plt.close()

    # Отправка графика пользователю
    await message.answer_photo(
        photo=types.BufferedInputFile(buffer.getvalue(), filename="plot.png"),
        caption="📊 График затрат по дням"
    )

@dp.message()
async def buget(message: types.Message):
    global date0
