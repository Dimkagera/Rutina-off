@dp.message(Command("expenses"))
async def cmd_expenses(message: types.Message):
    user_expected_file[message.from_user.id] = "expense"
    await message.answer("📤 Отправь файл твоих расходов (.xlsx). Данные заменят текущие.")

@dp.message(Command("plan"))
async def cmd_plan(message: types.Message):
    user_expected_file[message.from_user.id] = "plan"
    await message.answer("📤 Отправь файл твоего плана расходов (.xlsx).")

@dp.message(Command('buttons'))
async def get_main_keyboard(message: types.Message):
    kb = [
        [types.KeyboardButton(text="📊 Сравнение с планом")],
        [types.KeyboardButton(text="💰 График расходов")],
