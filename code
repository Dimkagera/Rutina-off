@dp.message(lambda message: message.document)
async def handle(message: types.Message):
    """
    Обработчик загруженных документов (для файла расходов)

    Загружает файл Excel, проверяет формат и сохраняет данные в глобальную переменную expenses.

    Args:
        message (types.Message): Объект сообщения с документом

    Global:
        expenses: DataFrame с данными о расходах

    Примечание:
        Этот обработчик будет вызван для ЛЮБОГО документа, отправленного боту
    """
    global expenses
    document = message.document

    # Проверка расширения файла
    if not (document.file_name.endswith('.xlsx')):
        await message.answer("Отправь файл в формате .xlsx")
        return

    await message.answer("Файл получен")

    # Создание временного файла для сохранения загруженного Excel
    with tempfile.NamedTemporaryFile(delete=False, suffix='.xlsx') as tmp_file:
        file = await bot.get_file(document.file_id)
        await bot.download_file(file.file_path, tmp_file.name)
        tmp_path = tmp_file.name
        expenses = pd.read_excel(tmp_path)


