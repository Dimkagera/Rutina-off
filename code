@dp.message(Command("expenses"))
async def cmd_expenses(message: types.Message):
    user_expected_file[message.from_user.id] = "expense"
    await message.answer("📤 Отправь файл твоих расходов (.xlsx). Данные заменят текущие.")

@dp.message(Command("plan"))
async def cmd_plan(message: types.Message):
    user_expected_file[message.from_user.id] = "plan"
    await message.answer("📤 Отправь файл твоего плана расходов (.xlsx).")

@dp.message(Command('buttons'))
async def get_main_keyboard(message: types.Message):
    kb = [
        [types.KeyboardButton(text="📊 Сравнение с планом")],
        [types.KeyboardButton(text="💰 График расходов")]
    ]
    keyboard = types.ReplyKeyboardMarkup(keyboard=kb, resize_keyboard=True)
    await message.answer("Выберите действие:", reply_markup=keyboard)

@dp.message(Command("reset"))
async def reset_data(message: types.Message):
    """Очистка данных пользователя"""
    user_id = message.from_user.id
    expense_path = get_user_file_path(user_id, "expense")
    plan_path = get_user_file_path(user_id, "plan")
    for path in [expense_path, plan_path]:
        if os.path.exists(path):
            os.remove(path)
    await message.answer("🗑️ Все ваши данные удалены. Отправьте новые расходы.")

# ==================== ОБРАБОТКА ФАЙЛОВ ====================

@dp.message(F.document & F.document.file_name.endswith(".xlsx"))
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    mode = user_expected_file.get(user_id, "expense")  # По умолчанию считаем файл расходами
    file_path = get_user_file_path(user_id, mode)

    await message.answer("⏳ Файл получен, обрабатываю...")
    try:
        file = await bot.get_file(message.document.file_id)
        with tempfile.NamedTemporaryFile(delete=False, suffix='.xlsx') as tmp:
            await bot.download_file(file.file_path, tmp.name)
            df = pd.read_excel(tmp.name)
        
        # Приводим к стандартной структуре, если заголовки отличаются
        if len(df.columns) >= 3:
            df.columns = ["Затраты", "Дата", "Деньги"]
            df.to_excel(file_path, index=False)
            label = "расходов" if mode == "expense" else "плана"
            await message.answer(f"✅ Данные {label} успешно сохранены!")
        else:
            await message.answer("❌ В файле должно быть минимум 3 столбца.")
    except Exception as e:
        await message.answer(f"❌ Ошибка чтения файла: {e}")
    finally:
        user_expected_file.pop(user_id, None)

# ==================== ПРИЁМ РАСХОДОВ ЧЕРЕЗ ТЕКСТ ====================

@dp.message(F.text & ~F.text.startswith("/"))
async def budget_handler(message: types.Message):
    user_id = message.from_user.id
    file_path = get_user_file_path(user_id, "expense")

    parts = message.text.strip().split()
    if len(parts) < 2:
        await message.answer("⚠️ Используйте формат: `Категория Сумма` (например: овощи 786)")
        return

    category = parts[0]
    try:
        amount = float(parts[1])
    except ValueError:
        await message.answer("⚠️ Сумма должна быть числом")
        return

    today = datetime.now().strftime("%Y-%m-%d")
    df = load_or_create_df(file_path)
    
    # Добавляем новую запись
    new_row = pd.DataFrame({"Затраты": [category], "Дата": [today], "Деньги": [amount]})
    df = pd.concat([df, new_row], ignore_index=True)
    
    # Сохраняем в персональный файл
    df.to_excel(file_path, index=False)
    await message.answer(f"✅ Добавлено: `{category}` — `{amount:.2f}` руб. ({today})")

# ==================== ПОСТРОЕНИЕ ГРАФИКА ====================

@dp.message(F.text == "💰 График расходов")
async def expenses_func(message: types.Message):
    user_id = message.from_user.id
    file_path = get_user_file_path(user_id, "expense")

    if not os.path.exists(file_path):
        await message.answer("📭 Нет данных для построения графика. Отправьте расходы или используйте /start")
        return

    df = load_or_create_df(file_path)
    if df.empty:
        await message.answer("📭 Таблица пуста. Добавьте расходы в формате: `Категория Сумма`")
        return

    # 1. Преобразование и сортировка
    df["Дата"] = pd.to_datetime(df["Дата"])
    df = df.sort_values("Дата")

    # 2. Сведение таблицы: Строки = Категории, Столбцы = Даты, Значения = Сумма
    # NaN в пустых ячейках автоматически пропускаются matplotlib
    pivot_df = df.pivot_table(index="Затраты", columns="Дата", values="Деньги", aggfunc="sum")

    if pivot_df.empty:
        await message.answer("📭 Недостаточно данных для построения графика")
        return

    # 3. Построение графика (автоматическая подстройка под количество дней/категорий)
    plt.figure(figsize=(10, 6))
    for category in pivot_df.index:
        y = pivot_df.loc[category]
        x = pivot_df.columns
        plt.plot(x, y, marker='o', linestyle='-', linewidth=2, markersize=6, label=category)

    plt.xlabel('Дата')
    plt.ylabel('Затраты (руб)')
    plt.title('📊 График затрат по дням')
    plt.legend(loc='upper left', bbox_to_anchor=(1, 1))
    plt.grid(True, alpha=0.3)
    plt.xticks(rotation=45, ha='right')
    plt.tight_layout()

    # 4. Сохранение в буфер и отправка
    buffer = BytesIO()
    plt.savefig(buffer, format='png', dpi=120, bbox_inches='tight')
    buffer.seek(0)
    plt.close()

    await message.answer_photo(
        photo=BufferedInputFile(buffer.getvalue(), filename="expenses_plot.png"),
        caption="📈 Ваш график готов. Пропущенные дни автоматически соединены линией."
    )

